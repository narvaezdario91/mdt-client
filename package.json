{
  "name": "mdt-client",
  "version": "1.0.0",
  "description": "CLI de orquestación para Meta-Driven Testing (MDT). Parsea escenarios Gherkin, mapea pasos YAML y ejecuta automatización web a través de servidores MCP.",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "dev": "ts-node src/cli/index.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "mdt",
    "meta-driven-testing",
    "bdd",
    "gherkin",
    "test-automation",
    "mcp",
    "playwright",
    "cli",
    "orchestrator"
  ],
  "author": "Dario Narvaez (https://github.com/narvaezdario91)",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@cucumber/gherkin": "^40.0.0",
    "@cucumber/messages": "^33.0.2",
    "axios": "^1.17.0",
    "commander": "^15.0.0",
    "cucumber-html-reporter": "^7.2.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
