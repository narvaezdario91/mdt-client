{
  "api": {
    "url": "http://localhost:8000"
  },
  "paths": {
    "features": "scenarios/features",
    "steps": "scenarios/steps",
    "reports": "executions/reports",
    "cache": "executions/cache"
  },
  "execution": {
    "useCache": false,
    "report": "allure"
  },
  "mcp": {
    "type": "stdio",
    "command": "npx",
    "args": [
      "-y", 
      "@playwright/mcp",
      "--isolated"
    ]
  }
}
